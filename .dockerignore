# Version control — never bake git history into the image
.git/
.github/

# Docker files themselves (no need to copy into the image)
Dockerfile
docker-compose.yml
.dockerignore

# Cache files are generated at runtime via tmpfs.
# Exception: the pre-built post metadata index is baked into the image by `make build-index`.
cache/

# Composer vendor — generated during Docker build stage, not needed in build context
vendor/

# Dev docs and tooling
README.md
AGENTS.md
Makefile
.htaccess

# Editor and OS noise
.DS_Store
*.log
*.tmp
.idea/
.vscode/
