# Version control — never bake git history into the image
.git/
.github/

# Docker files themselves (no need to copy into the image)
Dockerfile
docker-compose.yml
.dockerignore

# Cache files are generated at runtime via tmpfs and are not copied into the image.
# The pre-built post metadata index now lives at posts/posts.index.json and is included
# in the Docker build context by default (no cache/ exception rule is needed here).
cache/

# Composer vendor — generated during Docker build stage, not needed in build context
vendor/

# Dev docs and tooling
README.md
AGENTS.md
Makefile
.htaccess

# Editor and OS noise
.DS_Store
*.log
*.tmp
.idea/
.vscode/
