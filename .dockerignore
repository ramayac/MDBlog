# Version control
.git/
.github/

# Docker files (not needed inside build context)
Dockerfile
Dockerfile.embed
docker-compose.yml
.dockerignore

# Go build outputs — rebuilt inside the Docker build stage
bin/
vendor/

# PHP artifacts no longer in use
cache/
vendor/
composer.json
composer.lock
phpunit.xml
.phpunit.result.cache

# Dev docs and tooling
README.md
AGENTS.md
Makefile
.htaccess

